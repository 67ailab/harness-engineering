# Optional provider settings. Not required for the local demo or tests.
# For an OpenAI-compatible endpoint, set MODEL_PROVIDER=openai_compatible
# and provide OPENAI_BASE_URL / OPENAI_API_KEY / MODEL_NAME in a local .env file.
# This app also supports HARNESS_* variants to avoid collisions with inherited shell env.
HARNESS_OPENAI_BASE_URL=
HARNESS_OPENAI_API_KEY=
HARNESS_MODEL_PROVIDER=
HARNESS_MODEL_NAME=
OPENAI_BASE_URL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MODEL_PROVIDER=mock
MODEL_NAME=mock-local
