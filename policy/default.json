{
  "version": 1,
  "default_allowed_write_roots": [
    ".runs"
  ],
  "tool_policies": {
    "search_mock": {
      "enabled": true,
      "action_category": "read_only"
    },
    "extract_facts": {
      "enabled": true,
      "action_category": "transform"
    },
    "draft_report": {
      "enabled": true,
